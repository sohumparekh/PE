// Screen: Upload Files
// ====================================================================
function UploadScreen({ go, files, setFiles, user }) {
  const inputRef = useRef();
  const [loadingIds, setLoadingIds] = useState({});

  const addFiles = async (fileList) => {
    const incoming = Array.from(fileList);
    const newOnes = incoming.map(f => ({
      id: crypto.randomUUID(),
      name: f.name,
      size: f.size,
      type: f.type,
      pages: null,
      file: f
    }));
    setFiles(prev => [...prev, ...newOnes]);

    // count pages for PDFs
    for (const item of newOnes) {
      if (item.type === 'application/pdf') {
        setLoadingIds(s => ({ ...s, [item.id]: true }));
        const n = await countPdfPages(item.file);
        setFiles(prev => prev.map(p => p.id === item.id ? { ...p, pages: n } : p));
        setLoadingIds(s => { const c = { ...s }; delete c[item.id]; return c; });
      } else if (item.type.startsWith('image/')) {
        setFiles(prev => prev.map(p => p.id === item.id ? { ...p, pages: 1 } : p));
      } else {
        // estimate: 1 page per 80KB
        setFiles(prev => prev.map(p => p.id === item.id ? { ...p, pages: Math.max(1, Math.round(item.size / 80000)) } : p));
      }
    }
  };

  const onPick = (e) => {
    if (e.target.files?.length) addFiles(e.target.files);
    e.target.value = '';
  };

  const remove = (id) => setFiles(prev => prev.filter(p => p.id !== id));

  return (
    <div className="screen-enter min-h-full flex flex-col">
      <Header
        title={files.length ? `Files (${files.length})` : 'Upload Files'}
        right={<div className="text-xs font-bold text-brand-ink/60">Hi, {(user?.name || 'there').split(' ')[0]}</div>}
      />
      <div className="flex-1 px-5 pt-5 pb-8 flex flex-col">
        {files.length === 0 ? (
          <div className="flex-1 flex flex-col items-center justify-center text-center">
            <Logo size="md" faded animated={false} />
            <div className="mt-8 text-brand-ink/60 max-w-[280px]">
              Upload the documents you want printed. PDFs, images and more.
            </div>
          </div>
        ) : (
          <div className="space-y-3 flex-1">
            {files.map((f, i) => (
              <div key={f.id} className="card-stagger bg-brand-lavender rounded-2xl p-4 flex items-center gap-3" style={{ animationDelay: (i * 50) + 'ms' }}>
                <div className="w-12 h-12 rounded-xl bg-white flex items-center justify-center text-brand-blue flex-shrink-0">
                  <Icon.File className="w-6 h-6" />
                </div>
                <div className="flex-1 min-w-0">
                  <div className="font-display font-bold text-base text-brand-ink truncate">{f.name}</div>
                  <div className="text-xs text-brand-ink/60 mt-0.5 font-mono-tight tracking-wider">
                    {loadingIds[f.id] ? 'Reading...' : (f.pages ? `${f.pages} ${f.pages === 1 ? 'page' : 'pages'}` : '—')} · {fmtMB(f.size)}
                  </div>
                </div>
                <button
                  onClick={() => remove(f.id)}
                  className="w-9 h-9 rounded-full bg-white text-brand-ink/50 hover:text-red-500 flex items-center justify-center transition"
                  aria-label="Remove file"
                >
                  <Icon.Trash className="w-4 h-4" />
                </button>
              </div>
            ))}
          </div>
        )}

        <input ref={inputRef} type="file" multiple accept=".pdf,image/*,.doc,.docx" onChange={onPick} className="hidden" />

        <div className="space-y-3 mt-6">
          <button
            onClick={() => inputRef.current?.click()}
            className="w-full h-14 rounded-2xl bg-brand-lavender hover:bg-brand-lavender-dark text-brand-ink font-display font-bold text-lg flex items-center justify-center gap-2 transition active:scale-[0.98]"
          >
            <Icon.Plus className="w-5 h-5" />
            UPLOAD FILES
          </button>
          {files.length > 0 && (
            <PrimaryButton
              disabled={files.some(f => f.pages === null)}
              onClick={() => go('options')}
            >
              Continue
            </PrimaryButton>
          )}
        </div>
      </div>
    </div>
  );
}

