// ====================================================================
// Pricing calculation (used by Summary & Payment)
// ====================================================================
function calcPricing(files, options) {
  const totalPages = files.reduce((s, f) => s + (f.pages || 0), 0);
  const perPageRate = PRICING.paperSize[options.paperSize] * PRICING.colorMultiplier[options.color];
  const printCost = totalPages * options.copies * perPageRate;
  const bindingCost = PRICING.binding[options.binding] * options.copies;
  const subtotal = printCost + bindingCost;
  const freeDelivery = PRICING.freeDeliveryThreshold && subtotal >= PRICING.freeDeliveryThreshold;
  const delivery = freeDelivery ? 0 : PRICING.deliveryCharge;
  const total = subtotal + delivery;
  return { totalPages, perPageRate, printCost, bindingCost, subtotal, delivery, freeDelivery, total };
}

