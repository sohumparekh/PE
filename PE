</script>
<script src="https://unpkg.com/react@18/umd/react.production.min.js" crossorigin></script>
<script src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js" crossorigin></script>
<script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js"></script>
<style>
  html, body { margin: 0; padding: 0; }
  body {
    font-family: 'Manrope', system-ui, sans-serif;
    background: linear-gradient(135deg, #EDEEFD 0%, #F5F6FF 50%, #EAECFC 100%);
    min-height: 100vh;
    -webkit-font-smoothing: antialiased;
    color: #0F1330;
  }
  .font-display { font-family: 'Bricolage Grotesque', system-ui, sans-serif; letter-spacing: -0.01em; }
  .font-mono-tight { font-family: 'JetBrains Mono', monospace; }

  /* Decorative background blobs visible only on desktop */
  body::before, body::after {
    content: '';
    position: fixed;
    border-radius: 50%;
    filter: blur(80px);
    z-index: 0;
    pointer-events: none;
    opacity: 0.5;
  }
  body::before {
    width: 380px; height: 380px;
    background: radial-gradient(circle, #F58220 0%, transparent 70%);
    top: -100px; left: -100px;
  }
  body::after {
    width: 460px; height: 460px;
    background: radial-gradient(circle, #2E9D38 0%, transparent 70%);
    bottom: -150px; right: -120px;
  }
  @media (max-width: 767px) {
    body::before, body::after { display: none; }
  }

  ::-webkit-scrollbar { width: 6px; height: 6px; }
  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb { background: #C4C7F2; border-radius: 3px; }

  input[type="number"]::-webkit-outer-spin-button,
  input[type="number"]::-webkit-inner-spin-button { -webkit-appearance: none; margin: 0; }
  input[type="number"] { -moz-appearance: textfield; }

  /* Screen transition */
  @keyframes screenIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .screen-enter { animation: screenIn 0.32s cubic-bezier(0.22, 1, 0.36, 1); }

  @keyframes pulseRing {
    0% { transform: scale(0.95); opacity: 0.6; }
    50% { transform: scale(1.05); opacity: 0.2; }
    100% { transform: scale(0.95); opacity: 0.6; }
  }
  .pulse-ring { animation: pulseRing 1.6s ease-in-out infinite; }

  @keyframes runnerBob {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-2px); }
  }
  .runner-bob { animation: runnerBob 1.2s ease-in-out infinite; transform-origin: center; }

  @keyframes dashFly {
    0% { transform: translateX(-4px); opacity: 0.3; }
    50% { opacity: 1; }
    100% { transform: translateX(4px); opacity: 0.3; }
  }
  .dash-fly-1 { animation: dashFly 1.2s ease-in-out infinite; }
  .dash-fly-2 { animation: dashFly 1.2s ease-in-out infinite 0.2s; }
  .dash-fly-3 { animation: dashFly 1.2s ease-in-out infinite 0.4s; }

  /* Phone shell on desktop */
  .phone-shell {
    background: #F8F9FF;
    min-height: 100vh;
    position: relative;
    z-index: 1;
  }
  @media (min-width: 768px) {
    .phone-shell {
      max-width: 440px;
      margin: 28px auto;
      border-radius: 40px;
      box-shadow: 0 30px 80px -20px rgba(27, 77, 191, 0.28), 0 12px 28px -10px rgba(15, 19, 48, 0.12);
      overflow: hidden;
      min-height: calc(100vh - 56px);
      max-height: calc(100vh - 56px);
      border: 8px solid #0F1330;
    }
  }

  /* OTP input */
  .otp-input {
    width: 54px; height: 64px;
    text-align: center;
    font-size: 26px; font-weight: 700;
    font-family: 'Bricolage Grotesque', sans-serif;
    border: 2px solid #C4C7F2;
    border-radius: 14px;
    background: white;
    transition: all 0.15s;
    color: #0F1330;
  }
  .otp-input:focus {
    outline: none;
    border-color: #1B4DBF;
    box-shadow: 0 0 0 4px rgba(27,77,191,0.12);
  }

  /* Chip selectable */
  .chip {
    padding: 10px 14px;
    border-radius: 12px;
    background: white;
    border: 2px solid transparent;
    font-weight: 600;
    color: #0F1330;
    cursor: pointer;
    transition: all 0.15s;
    font-size: 14px;
  }
  .chip:hover { border-color: #C4C7F2; }
  .chip-active {
    background: #1B4DBF;
    color: white;
    border-color: #1B4DBF;
    box-shadow: 0 4px 14px -4px rgba(27, 77, 191, 0.5);
  }

  /* Loader spinner */
  @keyframes spin { to { transform: rotate(360deg); } }
  .spinner {
    width: 48px; height: 48px;
    border: 4px solid #DDE0FB;
    border-top-color: #1B4DBF;
    border-radius: 50%;
    animation: spin 0.9s linear infinite;
  }

  /* Success check draw */
  @keyframes drawCheck {
    from { stroke-dashoffset: 60; }
    to { stroke-dashoffset: 0; }
  }
  .check-anim { stroke-dasharray: 60; stroke-dashoffset: 60; animation: drawCheck 0.5s ease-out 0.2s forwards; }

  @keyframes circleScale {
    from { transform: scale(0); }
    to { transform: scale(1); }
  }
  .circle-anim { transform-origin: center; animation: circleScale 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) forwards; }

  /* Demo badge */
  .demo-badge {
    position: fixed;
    top: 12px;
    right: 12px;
    z-index: 50;
    background: rgba(15, 19, 48, 0.85);
    color: white;
    padding: 4px 10px;
    border-radius: 20px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.04em;
    backdrop-filter: blur(8px);
    text-transform: uppercase;
  }
  @media (max-width: 767px) {
    .demo-badge { top: 8px; right: 8px; }
  }

  /* Smooth focus */
  input:focus, textarea:focus, select:focus { outline: none; }

  /* Slide in cards stagger */
  @keyframes cardIn {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .card-stagger { animation: cardIn 0.4s ease-out backwards; }
</style>
</head>
<body>
<div class="demo-badge">Demo Mode</div>
<div id="root"></div>

<script type="text/babel" data-presets="env,react">
const { useState, useEffect, useRef, useCallback, useMemo } = React;

// ====================================================================
// PRICING CONFIG — edit these values to change pricing across the app
// ====================================================================
const PRICING = {
  // Cost per page (in INR) by paper size
  paperSize: {
    A5: 0.50,
    A4: 1.00,
    A3: 2.00,
    A2: 5.00,
    A1: 10.00,
    A0: 20.00
  },
  // Multiplier on per-page rate
  colorMultiplier: {
    'B/W':    1,
    'Colour': 3
  },
  // One-time cost per copy
  binding: {
    'No Binding':     0,
    'Staple':         5,
    'Spiral Binding': 30
  },
  // Flat delivery
  deliveryCharge: 50,
  // Above this order subtotal, delivery is free (set to null to disable)
  freeDeliveryThreshold: 500
};

const REGISTERED_ADDRESS = 'E/619-620, Raj Garden, Mahavir Nagar, Kandivali (W), Mumbai - 67. Maharashtra.';

// ====================================================================
// pdf.js setup for page counting
// ====================================================================
if (window['pdfjsLib']) {
  window['pdfjsLib'].GlobalWorkerOptions.workerSrc =
    'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';
}

async function countPdfPages(file) {
  try {
    const arrayBuffer = await file.arrayBuffer();
    const pdf = await window['pdfjsLib'].getDocument({ data: arrayBuffer }).promise;
    return pdf.numPages;
  } catch (e) {
    console.warn('Could not read PDF page count, defaulting to 1', e);
    return 1;
  }
}

// ====================================================================
// Utility helpers
// ====================================================================
const fmtMB = (bytes) => {
  if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(1) + ' KB';
  return (bytes / (1024 * 1024)).toFixed(1) + ' MB';
};
const fmtINR = (n) => '₹' + Math.round(n).toLocaleString('en-IN');
const fmtINR2 = (n) => '₹' + (Math.round(n * 100) / 100).toLocaleString('en-IN', { minimumFractionDigits: 0, maximumFractionDigits: 2 });
const genOrderId = () => 'PE' + Date.now().toString().slice(-6) + Math.floor(Math.random() * 90 + 10);
const clsx = (...c) => c.filter(Boolean).join(' ');

// ====================================================================
// Brand Logo SVG
// ====================================================================
function Logo({ size = 'lg', faded = false, animated = true }) {
  const sizes = {
    sm: { wrap: 'gap-1', svg: 36, title: 'text-lg', tag: 'text-[8px]' },
    md: { wrap: 'gap-1.5', svg: 56, title: 'text-2xl', tag: 'text-[10px]' },
    lg: { wrap: 'gap-2', svg: 92, title: 'text-4xl', tag: 'text-[11px]' }
  };
  const s = sizes[size];
  const op = faded ? 0.18 : 1;
  return (
    <div className={clsx('flex flex-col items-center', s.wrap)} style={{ opacity: op }}>
      <svg width={s.svg} height={s.svg} viewBox="0 0 120 120" fill="none" xmlns="http://www.w3.org/2000/svg">
        {/* Speed dashes */}
        <g className={animated ? '' : ''}>
          <rect className={animated ? 'dash-fly-1' : ''} x="6" y="42" width="18" height="4" rx="2" fill="#F58220"/>
          <rect className={animated ? 'dash-fly-2' : ''} x="2" y="54" width="22" height="4" rx="2" fill="#1B4DBF"/>
          <rect className={animated ? 'dash-fly-3' : ''} x="8" y="66" width="14" height="4" rx="2" fill="#2E9D38"/>
        </g>
        <g className={animated ? 'runner-bob' : ''}>
          {/* Document */}
          <path d="M 50 22 L 86 22 L 92 28 L 92 60 L 50 60 Z" fill="white" stroke="#1B4DBF" strokeWidth="3.5" strokeLinejoin="round"/>
          <path d="M 86 22 L 86 28 L 92 28" fill="none" stroke="#1B4DBF" strokeWidth="3.5" strokeLinejoin="round"/>
          <line x1="56" y1="32" x2="76" y2="32" stroke="#F58220" strokeWidth="2.5" strokeLinecap="round"/>
          <line x1="56" y1="40" x2="84" y2="40" stroke="#1B4DBF" strokeWidth="2.5" strokeLinecap="round"/>
          <line x1="56" y1="48" x2="78" y2="48" stroke="#2E9D38" strokeWidth="2.5" strokeLinecap="round"/>
          {/* Body */}
          <circle cx="58" cy="68" r="6" fill="#1B4DBF"/>
          <path d="M 52 76 L 50 96 L 58 96 L 60 82 Z" fill="#1B4DBF"/>
          <path d="M 60 76 L 68 92 L 74 90 L 66 78 Z" fill="#1B4DBF"/>
          {/* Legs */}
          <path d="M 50 96 L 44 110 L 50 110 L 56 98" fill="#1B4DBF"/>
          <path d="M 58 96 L 62 110 L 68 110 L 64 98" fill="#1B4DBF"/>
        </g>
      </svg>
      <div className="flex flex-col items-center" style={{ marginTop: size === 'lg' ? '6px' : '2px' }}>
        <div className={clsx('font-display font-extrabold tracking-tight leading-none', s.title)}>
          <span style={{ color: '#1B4DBF' }}>PRINT </span>
          <span style={{ color: '#F58220' }}>E</span>
          <span style={{ color: '#2E9D38' }}>X</span>
          <span style={{ color: '#1B4DBF' }}>PRESS</span>
        </div>
        <div className={clsx('font-semibold tracking-[0.18em] text-brand-ink/70 mt-1', s.tag)}>
          YOUR ONE STOP PRINTING SOLUTION
        </div>
      </div>
    </div>
  );
}

// ====================================================================
// Icons (inline SVG so no extra deps)
// ====================================================================
const Icon = {
  Back: (p) => <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2.2" strokeLinecap="round" strokeLinejoin="round" {...p}><path d="M19 12H5M12 19l-7-7 7-7"/></svg>,
  Upload: (p) => <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2.2" strokeLinecap="round" strokeLinejoin="round" {...p}><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M17 8l-5-5-5 5M12 3v12"/></svg>,
  File: (p) => <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round" {...p}><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>,
  Trash: (p) => <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round" {...p}><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6m5 0V4a2 2 0 0 1 2-2h0a2 2 0 0 1 2 2v2"/></svg>,
  Plus: (p) => <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2.2" strokeLinecap="round" strokeLinejoin="round" {...p}><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>,
  Minus: (p) => <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2.2" strokeLinecap="round" strokeLinejoin="round" {...p}><line x1="5" y1="12" x2="19" y2="12"/></svg>,
  Check: (p) => <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2.5" strokeLinecap="round" strokeLinejoin="round" {...p}><polyline points="20 6 9 17 4 12"/></svg>,
  Pin: (p) => <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round" {...p}><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>,
  Card: (p) => <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round" {...p}><rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/></svg>,
  Phone: (p) => <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round" {...p}><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>,
  Bank: (p) => <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round" {...p}><path d="M3 21h18M3 10h18M5 6l7-3 7 3M4 10v11M20 10v11M8 14v3M12 14v3M16 14v3"/></svg>,
  Clock: (p) => <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round" {...p}><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>,
  Edit: (p) => <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round" {...p}><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>,
  Home: (p) => <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round" {...p}><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
};

// ====================================================================
// Reusable layout pieces
// ====================================================================
function Header({ title, onBack, right }) {
  return (
    <div className="sticky top-0 z-30 backdrop-blur bg-brand-lavender-light/85 border-b border-brand-lavender-dark/30">
      <div className="flex items-center gap-3 px-5 py-4">
        {onBack ? (
          <button
            onClick={onBack}
            className="w-9 h-9 rounded-full bg-white shadow-card flex items-center justify-center text-brand-ink hover:bg-brand-lavender transition active:scale-95"
            aria-label="Back"
          >
            <Icon.Back className="w-4 h-4" />
          </button>
        ) : <div className="w-9 h-9" />}
        <div className="flex-1 font-display font-bold text-lg text-brand-ink truncate">{title}</div>
        <div className="min-w-[36px] flex justify-end">{right}</div>
      </div>
    </div>
  );
}

function PrimaryButton({ children, onClick, disabled, full = true, loading }) {
  return (
    <button
      onClick={onClick}
      disabled={disabled || loading}
      className={clsx(
        'h-14 rounded-2xl font-display font-bold text-lg transition-all active:scale-[0.98]',
        full ? 'w-full' : 'px-6',
        disabled || loading
          ? 'bg-brand-lavender-dark text-brand-ink/40 cursor-not-allowed'
          : 'bg-brand-blue text-white shadow-soft hover:bg-brand-blue-dark'
      )}
    >
      {loading ? (
        <span className="inline-flex items-center gap-2">
          <span className="w-4 h-4 rounded-full border-2 border-white/30 border-t-white animate-spin"></span>
          Processing...
        </span>
      ) : children}
    </button>
  );
}

function SectionCard({ title, children, className }) {
  return (
    <div className={clsx('bg-brand-lavender rounded-2xl p-5 card-stagger', className)}>
      <div className="font-display font-bold text-xl text-brand-ink mb-3">{title}</div>
      {children}
    </div>
  );
}

// ====================================================================
// Screen: Welcome
// ====================================================================
function WelcomeScreen({ go }) {
  return (
    <div className="screen-enter min-h-full flex flex-col px-6 pt-8 pb-8">
      <div className="flex-1 flex items-center justify-center">
        <Logo size="lg" />
      </div>
      <div className="grid grid-cols-2 gap-3 mt-6">
        <button
          onClick={() => go('login')}
          className="h-14 rounded-2xl bg-brand-lavender text-brand-ink font-display font-bold text-lg shadow-card hover:bg-brand-lavender-dark transition active:scale-[0.98]"
        >
          LOGIN
        </button>
        <button
          onClick={() => go('signup')}
          className="h-14 rounded-2xl bg-brand-blue text-white font-display font-bold text-lg shadow-soft hover:bg-brand-blue-dark transition active:scale-[0.98]"
        >
          SIGN UP
        </button>
      </div>
    </div>
  );
}

// ====================================================================
// Screen: Login (phone)
// ====================================================================
function LoginScreen({ go, setUser }) {
  const [phone, setPhone] = useState('');
  const valid = /^\d{10}$/.test(phone);
  return (
    <div className="screen-enter min-h-full flex flex-col">
      <Header title="Login" onBack={() => go('welcome')} />
      <div className="flex-1 px-6 pt-6 pb-8 flex flex-col">
        <div className="mb-6">
          <div className="font-display font-bold text-2xl text-brand-ink">Welcome back</div>
          <div className="text-brand-ink/60 mt-1">We'll send an OTP to verify your number</div>
        </div>
        <label className="block text-sm font-semibold text-brand-ink/70 mb-2 tracking-wide uppercase">Mobile Number</label>
        <div className="flex items-center bg-white rounded-2xl border-2 border-brand-lavender-dark focus-within:border-brand-blue transition px-4 py-3">
          <span className="text-brand-ink/60 font-medium mr-2">+91</span>
          <input
            type="tel"
            inputMode="numeric"
            maxLength="10"
            value={phone}
            onChange={(e) => setPhone(e.target.value.replace(/\D/g, ''))}
            placeholder="98765 43210"
            className="flex-1 bg-transparent text-lg font-medium text-brand-ink placeholder:text-brand-ink/30"
            autoFocus
          />
        </div>
        <div className="mt-3 text-xs text-brand-ink/50">
          By continuing, you agree to our Terms of Service and Privacy Policy.
        </div>
        <div className="flex-1"></div>
        <PrimaryButton
          disabled={!valid}
          onClick={() => { setUser((u) => ({ ...(u || {}), phone })); go('otp', { mode: 'login' }); }}
        >
          Get OTP
        </PrimaryButton>
        <div className="text-center mt-4 text-sm text-brand-ink/60">
          New to Print Express?{' '}
          <button onClick={() => go('signup')} className="text-brand-blue font-bold">Sign up</button>
        </div>
      </div>
    </div>
  );
}

// ====================================================================
// Screen: Signup
// ====================================================================
function SignupScreen({ go, setUser }) {
  const [name, setName] = useState('');
  const [email, setEmail] = useState('');
  const [phone, setPhone] = useState('');
  const valid = name.trim().length > 1 && /^[^@\s]+@[^@\s]+\.[^@\s]+$/.test(email) && /^\d{10}$/.test(phone);
  return (
    <div className="screen-enter min-h-full flex flex-col">
      <Header title="Sign Up" onBack={() => go('welcome')} />
      <div className="flex-1 px-6 pt-6 pb-8 flex flex-col">
        <div className="mb-6">
          <div className="font-display font-bold text-2xl text-brand-ink">Create your account</div>
