                  <div className={clsx('text-xs mt-0.5', method === o.id ? 'text-white/70' : 'text-brand-ink/55')}>{o.sub}</div>
                </div>
                <div className={clsx('w-5 h-5 rounded-full border-2 flex items-center justify-center', method === o.id ? 'border-white' : 'border-brand-lavender-dark')}>
                  {method === o.id && <div className="w-2.5 h-2.5 rounded-full bg-white"></div>}
                </div>
              </button>
            ))}
          </div>
        </SectionCard>

        <div className="mt-6">
          <PrimaryButton disabled={!method} onClick={() => { setPaymentMethod(method); go('processing'); }}>
            Pay {fmtINR2(p.total)}
          </PrimaryButton>
          <div className="text-center text-xs text-brand-ink/50 mt-3">
            Demo only · No real charge will be made.
          </div>
        </div>
      </div>
    </div>
  );
}

function UpiIcon({ brand }) {
  if (brand === 'gpay') return (
    <svg viewBox="0 0 24 24" className="w-5 h-5"><circle cx="12" cy="12" r="10" fill="#4285F4"/><text x="12" y="16" textAnchor="middle" fontSize="10" fontWeight="700" fill="white" fontFamily="sans-serif">G</text></svg>
  );
  return (
    <svg viewBox="0 0 24 24" className="w-5 h-5"><circle cx="12" cy="12" r="10" fill="#00B9F1"/><text x="12" y="16" textAnchor="middle" fontSize="8" fontWeight="700" fill="white" fontFamily="sans-serif">P</text></svg>
  );
}

// ====================================================================
// Screen: Processing (mock payment)
// ====================================================================
function ProcessingScreen({ go, setOrderId }) {
  const [stage, setStage] = useState(0);
  const stages = ['Connecting to payment gateway', 'Authorizing payment', 'Confirming order'];

  useEffect(() => {
    const timers = [
      setTimeout(() => setStage(1), 900),
      setTimeout(() => setStage(2), 1800),
      setTimeout(() => { setOrderId(genOrderId()); go('success'); }, 2700)
    ];
    return () => timers.forEach(clearTimeout);
  }, []);

  return (
    <div className="screen-enter min-h-full flex flex-col items-center justify-center px-6 pb-8">
      <div className="relative mb-8">
        <div className="absolute inset-0 rounded-full bg-brand-blue/20 pulse-ring"></div>
        <div className="relative w-24 h-24 rounded-full bg-white shadow-soft flex items-center justify-center">
          <div className="spinner"></div>
        </div>
      </div>
      <div className="font-display font-bold text-2xl text-brand-ink text-center">Processing your payment</div>
      <div className="text-brand-ink/60 mt-2 text-center">Please don't close this screen</div>
      <div className="mt-8 space-y-2 w-full max-w-xs">
        {stages.map((s, i) => (
          <div key={i} className={clsx('flex items-center gap-2 text-sm transition', i <= stage ? 'text-brand-ink' : 'text-brand-ink/30')}>
            <div className={clsx('w-5 h-5 rounded-full flex items-center justify-center flex-shrink-0', i < stage ? 'bg-brand-green text-white' : (i === stage ? 'bg-brand-blue text-white' : 'bg-brand-lavender'))}>
              {i < stage && <Icon.Check className="w-3 h-3" />}
              {i === stage && <div className="w-2 h-2 rounded-full bg-white"></div>}
            </div>
            <span className="font-medium">{s}</span>
          </div>
        ))}
      </div>
    </div>
  );
}

// ====================================================================
// Screen: Success
// ====================================================================
function SuccessScreen({ go, files, options, orderId, reset, user, address }) {
  const p = useMemo(() => calcPricing(files, options), [files, options]);
  const eta = useMemo(() => {
    const now = new Date();
    const min = new Date(now.getTime() + 30 * 60000);
    const max = new Date(now.getTime() + 45 * 60000);
    const f = (d) => d.toLocaleTimeString('en-IN', { hour: 'numeric', minute: '2-digit', hour12: true });
    return `${f(min)} - ${f(max)}`;
  }, []);
  const deliveryAddress = address.useNew ? address.newAddress : REGISTERED_ADDRESS;

  return (
    <div className="screen-enter min-h-full flex flex-col">
      <div className="flex-1 px-6 pt-12 pb-8 flex flex-col">
        <div className="flex flex-col items-center text-center">
          <svg width="96" height="96" viewBox="0 0 96 96">
            <circle className="circle-anim" cx="48" cy="48" r="44" fill="#2E9D38"/>
            <polyline className="check-anim" points="28,50 42,62 68,36" fill="none" stroke="white" strokeWidth="6" strokeLinecap="round" strokeLinejoin="round"/>
          </svg>
          <div className="font-display font-extrabold text-3xl text-brand-ink mt-5">Order Confirmed!</div>
          <div className="text-brand-ink/60 mt-2 max-w-xs">
            Thanks {(user?.name || '').split(' ')[0] || 'mate'}, your prints are on the way.
          </div>
        </div>

        <div className="bg-brand-lavender rounded-2xl p-5 mt-8">
          <div className="flex items-center justify-between mb-4 pb-4 border-b border-brand-lavender-dark/40">
            <div>
              <div className="text-xs font-semibold tracking-wider uppercase text-brand-ink/60">Order ID</div>
              <div className="font-mono-tight font-bold text-lg text-brand-ink">{orderId}</div>
            </div>
            <div className="text-right">
              <div className="text-xs font-semibold tracking-wider uppercase text-brand-ink/60">Amount Paid</div>
              <div className="font-display font-bold text-lg text-brand-blue">{fmtINR2(p.total)}</div>
            </div>
          </div>

          <div className="flex items-start gap-3">
            <div className="w-10 h-10 rounded-xl bg-white text-brand-blue flex items-center justify-center flex-shrink-0">
              <Icon.Clock className="w-5 h-5" />
            </div>
            <div className="flex-1">
              <div className="text-xs font-semibold tracking-wider uppercase text-brand-ink/60">Estimated Delivery</div>
              <div className="font-display font-bold text-brand-ink">{eta}</div>
              <div className="text-xs text-brand-ink/60 mt-0.5">30 - 45 minutes</div>
            </div>
          </div>

          <div className="flex items-start gap-3 mt-4">
            <div className="w-10 h-10 rounded-xl bg-white text-brand-orange flex items-center justify-center flex-shrink-0">
              <Icon.Pin className="w-5 h-5" />
            </div>
            <div className="flex-1">
              <div className="text-xs font-semibold tracking-wider uppercase text-brand-ink/60">Delivery Address</div>
              <div className="text-sm text-brand-ink/85 leading-relaxed mt-0.5">{deliveryAddress}</div>
            </div>
          </div>

          <div className="flex items-start gap-3 mt-4">
            <div className="w-10 h-10 rounded-xl bg-white text-brand-green flex items-center justify-center flex-shrink-0">
              <Icon.File className="w-5 h-5" />
            </div>
            <div className="flex-1">
              <div className="text-xs font-semibold tracking-wider uppercase text-brand-ink/60">Print Job</div>
              <div className="text-sm text-brand-ink/85 mt-0.5">
                {files.length} {files.length === 1 ? 'file' : 'files'} · {p.totalPages} pages · {options.copies} {options.copies === 1 ? 'copy' : 'copies'} · {options.paperSize} {options.color} · {options.binding}
              </div>
            </div>
          </div>
        </div>

        <div className="flex-1"></div>
        <div className="space-y-3 mt-8">
          <PrimaryButton onClick={() => { reset(); go('upload'); }}>Place Another Order</PrimaryButton>
          <button
            onClick={() => alert('Order tracking is not part of this demo flow.')}
            className="w-full h-12 rounded-2xl bg-white text-brand-ink font-display font-bold border-2 border-brand-lavender-dark hover:bg-brand-lavender-light transition"
          >
            Track Order
          </button>
        </div>
      </div>
    </div>
  );
}

// ====================================================================
// Main App
// ====================================================================
function App() {
  const [screen, setScreen] = useState('welcome');
  const [screenPayload, setScreenPayload] = useState(null);
  const [user, setUser] = useState(null);
  const [files, setFiles] = useState([]);
  const [options, setOptions] = useState({
    paperSize: 'A4',
    color: 'B/W',
    copies: 1,
    binding: 'No Binding'
  });
  const [address, setAddress] = useState({
    newAddress: '',
    useNew: false
  });
  const [paymentMethod, setPaymentMethod] = useState(null);
  const [orderId, setOrderId] = useState(null);

  const go = useCallback((next, payload = null) => {
    setScreenPayload(payload);
    setScreen(next);
    window.scrollTo({ top: 0, behavior: 'instant' });
  }, []);

  const resetOrder = useCallback(() => {
    setFiles([]);
    setOptions({ paperSize: 'A4', color: 'B/W', copies: 1, binding: 'No Binding' });
    setAddress({ newAddress: '', useNew: false });
    setPaymentMethod(null);
    setOrderId(null);
  }, []);

  let body;
  switch (screen) {
    case 'welcome':     body = <WelcomeScreen go={go} />; break;
    case 'login':       body = <LoginScreen go={go} setUser={setUser} />; break;
    case 'signup':      body = <SignupScreen go={go} setUser={setUser} />; break;
    case 'otp':         body = <OTPScreen go={go} payload={screenPayload} user={user} />; break;
    case 'upload':      body = <UploadScreen go={go} files={files} setFiles={setFiles} user={user} />; break;
    case 'options':     body = <OptionsScreen go={go} options={options} setOptions={setOptions} />; break;
    case 'address':     body = <AddressScreen go={go} address={address} setAddress={setAddress} />; break;
    case 'summary':     body = <SummaryScreen go={go} files={files} options={options} address={address} />; break;
    case 'payment':     body = <PaymentScreen go={go} files={files} options={options} setPaymentMethod={setPaymentMethod} />; break;
    case 'processing':  body = <ProcessingScreen go={go} setOrderId={setOrderId} />; break;
    case 'success':     body = <SuccessScreen go={go} files={files} options={options} orderId={orderId} reset={resetOrder} user={user} address={address} />; break;
    default:            body = <WelcomeScreen go={go} />;
  }

  return (
    <div className="phone-shell">
      {body}
    </div>
  );
}

ReactDOM.createRoot(document.getElementById('root')).render(<App />);
</script>
</body>
</html>
