// Screen: OTP
// ====================================================================
function OTPScreen({ go, payload, user }) {
  const [digits, setDigits] = useState(['', '', '', '']);
  const [error, setError] = useState('');
  const [secondsLeft, setSecondsLeft] = useState(30);
  const refs = [useRef(), useRef(), useRef(), useRef()];

  useEffect(() => {
    refs[0].current?.focus();
  }, []);
  useEffect(() => {
    if (secondsLeft <= 0) return;
    const t = setTimeout(() => setSecondsLeft(s => s - 1), 1000);
    return () => clearTimeout(t);
  }, [secondsLeft]);

  const onChange = (i, v) => {
    const digit = v.replace(/\D/g, '').slice(-1);
    const next = [...digits];
    next[i] = digit;
    setDigits(next);
    setError('');
    if (digit && i < 3) refs[i + 1].current?.focus();
  };

  const onKey = (i, e) => {
    if (e.key === 'Backspace' && !digits[i] && i > 0) refs[i - 1].current?.focus();
  };

  const onPaste = (e) => {
    const text = (e.clipboardData.getData('text') || '').replace(/\D/g, '').slice(0, 4);
    if (text.length === 4) {
      setDigits(text.split(''));
      refs[3].current?.focus();
    }
  };

  const verify = () => {
    const otp = digits.join('');
    if (otp === '1234') {
      go(payload?.mode === 'signup' ? 'upload' : 'upload', { fresh: true });
    } else {
      setError('Incorrect OTP. For this demo, use 1234.');
      setDigits(['', '', '', '']);
      refs[0].current?.focus();
    }
  };

  const filled = digits.every(d => d !== '');

  return (
    <div className="screen-enter min-h-full flex flex-col">
      <Header title="Verify OTP" onBack={() => go(payload?.mode === 'signup' ? 'signup' : 'login')} />
      <div className="flex-1 px-6 pt-6 pb-8 flex flex-col">
        <div className="mb-6">
          <div className="font-display font-bold text-2xl text-brand-ink">Enter the 4-digit code</div>
          <div className="text-brand-ink/60 mt-1">
            Sent to <span className="font-semibold text-brand-ink">+91 {user?.phone || ''}</span>
          </div>
        </div>

        <div className="flex justify-center gap-3 mb-3" onPaste={onPaste}>
          {digits.map((d, i) => (
            <input
              key={i}
              ref={refs[i]}
              className="otp-input"
              inputMode="numeric"
              maxLength="1"
              value={d}
              onChange={(e) => onChange(i, e.target.value)}
              onKeyDown={(e) => onKey(i, e)}
            />
          ))}
        </div>

        <div className="text-center text-xs text-brand-ink/50 mb-1">
          For this demo, the OTP is <span className="font-mono-tight font-bold text-brand-ink/80">1234</span>
        </div>
        {error && <div className="text-center text-sm text-red-600 font-semibold mt-2">{error}</div>}

        <div className="text-center mt-4 text-sm text-brand-ink/60">
          {secondsLeft > 0 ? (
            <span>Resend OTP in <span className="font-bold text-brand-ink">{secondsLeft}s</span></span>
          ) : (
            <button onClick={() => setSecondsLeft(30)} className="font-bold text-brand-blue">Resend OTP</button>
          )}
        </div>

        <div className="flex-1"></div>
        <PrimaryButton disabled={!filled} onClick={verify}>Verify & Continue</PrimaryButton>
      </div>
    </div>
  );
}

